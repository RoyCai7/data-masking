# Copy this file to .env and fill in your values
# Used by test scripts and tooling — NOT loaded by the backend (set via systemd or shell export)

# ── Server ────────────────────────────────────────────────────────────────────
# Base URL of the running service (used by mask_file.py, api_scenario_test.py, etc.)
DMS_SERVER=http://localhost:8080

# ── API Keys ──────────────────────────────────────────────────────────────────
# Admin API key for tests and scripts — generate with: python generate_key.py
DMS_ADMIN_KEY=dms_your_admin_key_here

# ── Email token delivery ──────────────────────────────────────────────────────
# Required for Web users to register/recover their token by email.
# Set these on the running backend process.
# DMS_SMTP_HOST=smtp.example.com
# DMS_SMTP_PORT=587
# DMS_SMTP_TLS=true
# DMS_SMTP_USER=no-reply@example.com
# DMS_SMTP_PASSWORD=change-me
# DMS_SMTP_FROM=no-reply@example.com
#
# Local/test only: include token in API response.
# Never enable this in production.
# DMS_EMAIL_DEBUG_RETURN_TOKEN=false

# ── LLM (Ollama) ──────────────────────────────────────────────────────────────
# Set on the server via systemd Environment= or export before running locally
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:7b

# ── E2E Tests (Playwright) ────────────────────────────────────────────────────
# Override base URL for Playwright — defaults to http://localhost:8080
# DMS_SERVER=http://your-server:8080
